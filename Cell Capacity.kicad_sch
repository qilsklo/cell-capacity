	(text "Pressing SW1 gives Arduino the signal to \nincrease voltage through A2 to the op-amp,\nwhich is the voltage across R4. SW2 decreases\nthat voltage."
		(exclude_from_sim no)
		(at 106.426 149.606 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "1a1eb5f7-89f9-46d1-8297-6e2d3deaa632")
	)
	(text "220uF prevents voltage sags, and 100nF is a low-pass filter."
		(exclude_from_sim no)
		(at 178.308 138.176 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "344a52a8-345a-4645-8110-4db0b9a928a7")
	)
	(text "R7 is a gate resistor for the IRLZ449N MOSFET."
		(exclude_from_sim no)
		(at 94.996 51.054 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "3d793b75-aa87-4256-ae8d-416fd53676c7")
	)
	(text "R3 and C3 form an RC-circuit / low-pass filter,\nwhich slowly ramps up the voltage going into\nnon-inverting pin. This smoothens the PWM signal\nfrom A2. Tau = 10^-3 s"
		(exclude_from_sim no)
		(at 133.096 93.726 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "87bde0b3-bf83-4acb-a8b1-03d0740b4544")
	)
	(text "USB required\n"
		(exclude_from_sim no)
		(at 145.288 24.892 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "9f205082-278b-4ca4-b64c-9f22a185534a")
	)
	(text "Need to filter VCC into op-amp via 100 nF cap.\n"
		(exclude_from_sim no)
		(at 28.702 116.84 90)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "ab3b1405-13c9-4299-ac58-e2dd33f097c9")
	)
	(text "A voltage divider circuit lets us compute the resistance of TH1,\nand its temperature via the Steinhart-Hart equation or the Beta formula.\n"
		(exclude_from_sim no)
		(at 242.824 145.796 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "d480c7aa-c78f-47ed-8a30-48412d300471")
	)
